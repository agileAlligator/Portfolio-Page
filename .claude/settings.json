{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/check-design-system.py\"",
            "timeout": 15,
            "statusMessage": "Design-system check"
          }
        ]
      }
    ]
  }
}
